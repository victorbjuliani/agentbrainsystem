# === Worktrees (repo convention: <repo-root>/.worktrees/) ===
.worktrees/

# === Spike scratch (throwaway validation; findings live in docs/adr/) ===
.spike/

# === Discovery / planning artifacts (GitHub Issues are the source of truth) ===
docs/discovery/

# === Node / TypeScript (stack lean — adjust when finalized) ===
node_modules/
node_modules
dist/
build/
*.tsbuildinfo

# === Tauri tray companion (src-tauri) ===
# Build output + Tauri-generated schemas/bindings (regenerated on build). The Rust
# sources, tauri.conf.json, capabilities, ui/ and icons/ ARE committed.
src-tauri/target/
src-tauri/gen/
*.tgz
.npm/
.pnpm-store/
coverage/
*.log

# === Secrets / local config ===
.env
.env.*
!.env.example
*.local

# === Memory store & runtime data (never commit a user's memory) ===
data/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# === Model / embedding cache ===
.cache/
models/

# === E2E suite (Playwright artifacts + temp scratch; suite is self-cleaning) ===
e2e/.tmp/
playwright-report/
test-results/
.playwright/
.playwright-mcp/

# === Editor / OS ===
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
# Added by code-review-graph
.code-review-graph/

# === Personal agent / dev tooling (machine-specific; not needed to clone & build) ===
# Local Claude Code config + code-review-graph hooks/skills (paths are hardcoded
# per machine), the code-review-graph MCP registration, and the atualizar-docs
# skill state file. Reproduced per-dev via each tool's install — never shared.
.claude/
.mcp.json
.atualizar-docs.json
# Per-dev agent wrappers (personal memory; kept local, never shared in git).
CLAUDE.md
AGENTS.md
HANDOFF.md

# Local-only reports / scratch (never shared in git).
production-readiness-report.md
