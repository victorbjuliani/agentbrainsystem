{
  "name": "agentbrainsystem",
  "version": "0.1.0",
  "description": "Local-first persistent memory for AI coding agents: reliable embed → persist → recall over MCP.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "abs": "./dist/cli/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:ui",
    "build:ui": "node scripts/build-ui.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.ui.json --noEmit && tsc -p tsconfig.e2e.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "pretest": "npm run build:ui",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && vitest run -c vitest.e2e.config.ts && playwright test -c playwright.config.ts",
    "dev": "tsx src/index.ts",
    "bench": "tsx bench/bench.ts",
    "check": "npm run lint && npm run typecheck && npm run test"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.10.0",
    "sqlite-vec": "^0.1.9",
    "zod": "^3.23.0 || ^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "d3-force": "^3.0.0",
    "esbuild": "^0.28.0",
    "force-graph": "^1.51.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
