Output e2e/live/gif/without.gif
Set Theme { "name": "abs", "background": "#0A0810", "foreground": "#E6E4ED", "cursor": "#8B5CF6", "selection": "#6D28D9", "black": "#0A0810", "red": "#F0ABFC", "green": "#5EEAD4", "yellow": "#FBBF24", "blue": "#22D3EE", "purple": "#8B5CF6", "cyan": "#22D3EE", "white": "#E6E4ED", "brightBlack": "#7A788A" }
Set FontSize 19
Set Width 900
Set Height 430
Set Padding 26
Set Framerate 12
Set PlaybackSpeed 1.0
Type "bash e2e/live/gif/play-panel.sh without"
Enter
Sleep 18s
